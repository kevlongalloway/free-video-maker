PEXELS_API_KEY= # crucial for the project to work
LOG_LEVEL=trace # trace, debug, info, warn, error, fatal, silent
WHISPER_VERBOSE=true
PORT=3123
DEV=true # local development mode
DATA_DIR_PATH= # only for docker, otherwise leave empty

# --- Multi-tenant / subscription mode (the ad-generation service) ---
# When ADMIN_API_KEY is set (or AUTH_ENABLED=true), the REST + MCP APIs require
# a per-customer API key. Leave both unset for single-user / local use.
AUTH_ENABLED=false
# The bootstrap admin key. Use it to call /api/admin/* and provision customers.
# Generate a strong random value, e.g.  openssl rand -hex 24
ADMIN_API_KEY=
